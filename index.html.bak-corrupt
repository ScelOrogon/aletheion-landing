   345|
   346|      function setLang(lang){
   347|        const m=t[lang];
   348|        Object.keys(m).forEach(k=>{
   349|          if(k==='htmlLang') return;
   350|          const el=document.getElementById(k);
   351|          if(!el) return;
   352|          if(k==='eyebrow') el.innerHTML=m[k]; else el.textContent=m[k];
   353|        });
   354|        document.documentElement.lang = m.htmlLang;
   355|        document.getElementById('langEN').classList.toggle('active', lang==='en');
   356|        document.getElementById('langFR').classList.toggle('active', lang==='fr');
   357|      }
   358|
   359|      document.getElementById('langEN').addEventListener('click',()=>setLang('en'));
   360|      document.getElementById('langFR').addEventListener('click',()=>setLang('fr'));
   361|      setLang('en');
   362|    })();
   363|  </script>
   364|</body>
   365|</html>
